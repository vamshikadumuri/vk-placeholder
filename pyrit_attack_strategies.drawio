<mxfile host="app.diagrams.net" modified="2026-07-17T00:00:00.000Z" agent="claude" version="24.0.0" type="device"><diagram name="Single-Turn" id="page1"><mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" page="1" pageWidth="1169" pageHeight="826" math="0" shadow="1"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="t" value="<b>PyRIT — Single-Turn Attack Strategies</b><br><font style='font-size:11px' color='#607D8B'>pyrit.executor.attack.single_turn  |  PyRIT 0.14.x  |  one objective → one crafted message → score → done</font>" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontStyle=1;fontColor=#102027;" vertex="1" parent="1"><mxGeometry x="40" y="24" width="0" height="0" as="geometry"/></mxCell><mxCell id="l1" value="<b>execute_async()</b><br><font style='font-size:10px' color='#546E7A'>public entry</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#ECEFF1;strokeColor=#546E7A;fontColor=#263238;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="40" y="84" width="168" height="48" as="geometry"/></mxCell><mxCell id="l2" value="<b>_validate_context()</b><br><font style='font-size:10px' color='#546E7A'>objective / params</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#ECEFF1;strokeColor=#546E7A;fontColor=#263238;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="238" y="84" width="168" height="48" as="geometry"/></mxCell><mxCell id="l3" value="<b>_setup_async()</b><br><font style='font-size:10px' color='#546E7A'>new conversation_id</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#ECEFF1;strokeColor=#546E7A;fontColor=#263238;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="436" y="84" width="168" height="48" as="geometry"/></mxCell><mxCell id="l4" value="<b>_perform_async()</b><br><font style='