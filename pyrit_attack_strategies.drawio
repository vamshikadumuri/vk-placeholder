CEFF1;strokeColor=#546E7A;fontColor=#263238;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="40" y="84" width="168" height="48" as="geometry"/></mxCell><mxCell id="l2" value="<b>_validate_context()</b><br><font style='font-size:10px' color='#546E7A'>objective / params</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#ECEFF1;strokeColor=#546E7A;fontColor=#263238;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="238" y="84" width="168" height="48" as="geometry"/></mxCell><mxCell id="l3" value="<b>_setup_async()</b><br><font style='font-size:10px' color='#546E7A'>new conversation_id</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#ECEFF1;strokeColor=#546E7A;fontColor=#263238;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="436" y="84" width="168" height="48" as="geometry"/></mxCell><mxCell id="l4" value="<b>_perform_async()</b><br><font style='font-size:10px' color='#546E7A'>the attack loop below</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#ECEFF1;strokeColor=#546E7A;fontColor=#263238;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="634" y="84" width="168" height="48" as="geometry"/></mxCell><mxCell id="l5" value="<b>_teardown_async()</b><br><font style='font-size:10px' color='#546E7A'>release resources</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#ECEFF1;strokeColor=#546E7A;fontColor=#263238;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="832" y="84" width="168" height="48" as="geometry"/></mxCell><mxCell id="cfg" value="<b>AttackAdversarialConfig</b><br><font style='font-size:10px' color='#546E7A'>target = adversarial chat (uncensored attacker)</font><br><font style='font-size:10px' color='#546E7A'>system_prompt_path · seed_prompt · objective</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#E3F2FD;strokeColor=#1565C0;fontColor=#0D47A1;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="60" y="186" width="300" height="74" as="geometry"/></mxCell><mxCell id="g" value="<b>_generate_next_prompt_async()</b><br><font style='font-size:10px' color='#546E7A'>attacker writes turn N from conversation state</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#FFFFFF;strokeColor=#455A64;fontColor=#263238;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="60" y="292" width="300" height="58" as="geometry"/></mxCell><mxCell id="adv" value="<b>Adversarial LLM</b><br><font style='font-size:10px' color='#546E7A'>e.g. Dolphin / Hermes via vLLM</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#FCE4EC;strokeColor=#AD1457;fontColor=#880E4F;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="60" y="384" width="300" height="58" as="geometry"/></mxCell><mxCell id="rc" value="<b>request_converters</b><br><font style='font-size:10px' color='#546E7A'>AttackConverterConfig</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#EDE7F6;strokeColor=#5E35B1;fontColor=#311B92;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="470" y="384" width="260" height="58" as="geometry"/></mxCell><mxCell id="tg" value="<b>objective_target</b><br><font style='font-size:10px' color='#546E7A'>system under test (multi-turn conversation_id)</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#FFF3E0;strokeColor=#E65100;fontColor=#BF360C;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="470" y="476" width="260" height="58" as="geometry"/></mxCell><mxCell id="rsp" value="<b>response_converters</b><br><font style='font-size:10px' color='#546E7A'>→ context.last_response</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#EDE7F6;strokeColor=#5E35B1;fontColor=#311B92;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="470" y="568" width="260" height="58" as="geometry"/></mxCell><mxCell id="dref" value="<b>refused ?</b><br><font style='font-size:10px' color='#546E7A'>refusal_scorer</font>" style="rhombus;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;fillColor=#FFFDE7;strokeColor=#F9A825;fontColor=#795548;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="500" y="656" width="200" height="92" as="geometry"/></mxCell><mxCell id="bt" value="<b>Backtrack  (Crescendo only)</b><br><font style='font-size:10px' color='#546E7A'>drop refused turn, keep memory of refusal,</font><br><font style='font-size:10px' color='#546E7A'>backtrack_count += 1 · turn NOT incremented</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4;fillColor=#FCE4EC;strokeColor=#AD1457;fontColor=#880E4F;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="60" y="664" width="300" height="76" as="geometry"/></mxCell><mxCell id="sc" value="<b>_score_response_async()</b><br><font style='font-size:10px' color='#546E7A'>objective_scorer (TrueFalseScorer)</font><br><font style='font-size:10px' color='#546E7A'>→ context.last_score</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1B5E20;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="470" y="786" width="260" height="62" as="geometry"/></mxCell><mxCell id="dobj" value="<b>objective</b><br><font style='font-size:10px' color='#546E7A'>achieved ?</font>" style="rhombus;whiteSpace=wrap;html=1;dashed=0;fillColor=#FFFDE7;strokeColor=#F9A825;fontColor=#795548;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="500" y="878" width="200" height="92" as="geometry"/></mxCell><mxCell id="inc" value="<b>context.executed_turns += 1</b>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#FFFFFF;strokeColor=#455A64;fontColor=#263238;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="470" y="1004" width="260" height="50" as="geometry"/></mxCell><mxCell id="dturn" value="<b>executed_turns</b><br><font style='font-size:10px' color='#546E7A'>&lt; max_turns ?</font>" style="rhombus;whiteSpace=wrap;html=1;dashed=0;fillColor=#FFFDE7;strokeColor=#F9A825;fontColor=#795548;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="480" y="1084" width="240" height="92" as="geometry"/></mxCell><mxCell id="ok" value="<b>AttackResult</b><br><font style='font-size:10px' color='#546E7A'>outcome = SUCCESS</font><br><font style='font-size:10px' color='#546E7A'>executed_turns, backtrack_count</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1B5E20;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="790" y="890" width="250" height="68" as="geometry"/></mxCell><mxCell id="bad" value="<b>AttackResult</b><br><font style='font-size:10px' color='#546E7A'>outcome = FAILURE</font><br><font style='font-size:10px' color='#546E7A'>max_turns reached</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#FFEBEE;strokeColor=#C62828;fontColor=#B71C1C;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="790" y="1096" width="250" height="68" as="geometry"/></mxCell><mxCell id="note" value="<b>Multi-turn strategies</b><br><font style='font-size:10px' color='#546E7A'></font><br><font style='font-size:10px'><b>RedTeamingAttack</b></font><br><font style='font-size:10px' color='#546E7A'>generic loop; adversarial LLM re-plans each turn</font><br><font style='font-size:10px' color='#546E7A'>from last_response (+ score rationale when</font><br><font style='font-size:10px' color='#546E7A'>use_score_as_feedback=True). RTASystemPromptPaths.</font><br><font style='font-size:10px' color='#546E7A'></font><br><font style='font-size:10px'><b>CrescendoAttack</b></font><br><font style='font-size:10px' color='#546E7A'>benign → gradual escalation; adds refusal_scorer</font><br><font style='font-size:10px' color='#546E7A'>+ backtracking (max_backtracks). Backtracks do</font><br><font style='font-size:10px' color='#546E7A'>not consume a turn. → CrescendoAttackResult.</font><br><font style='font-size:10px' color='#546E7A'></font><br><font style='font-size:10px'><b>TAPAttack / TreeOfAttacksWithPruningAttack</b></font><br><font style='font-size:10px' color='#546E7A'>tree search: branch, score, prune (see page 3)</font><br><font style='font-size:10px' color='#546E7A'></font><br><font style='font-size:10px'><b>PAIRAttack</b></font><br><font style='font-size:10px' color='#546E7A'>TAP with width=1 — iterative refinement</font><br><font style='font-size:10px' color='#546E7A'></font><br><font style='font-size:10px'><b>ChunkedRequestAttack</b></font><br><font style='font-size:10px' color='#546E7A'>split one payload across turns</font><br><font style='font-size:10px' color='#546E7A'></font><br><font style='font-size:10px'><b>MultiPromptSendingAttack</b></font><br><font style='font-size:10px' color='#546E7A'>fixed scripted prompt list, no adversary</font><br><font style='font-size:10px' color='#546E7A'></font><br><font style='font-size:10px' color='#546E7A'>Key contrast vs single-turn:</font><br><font style='font-size:10px' color='#546E7A'>state persists on one conversation_id, and the</font><br><font style='font-size:10px' color='#546E7A'>next prompt is a FUNCTION of the last response —</font><br><font style='font-size:10px' color='#546E7A'>this is the adaptive loop.</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#FAFAFA;strokeColor=#9E9E9E;fontColor=#424242;fontSize=12;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="790" y="186" width="300" height="620" as="geometry"/></mxCell><mxCell id="l1_l2_0" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="l1" target="l2"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="l2_l3_1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="l2" target="l3"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="l3_l4_2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="l3" target="l4"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="l4_l5_3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="l4" target="l5"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="l4_g_4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="l4" target="g"><mxGeometry relative="1" as="geometry"><Array as='points'><mxPoint x="678" y="158"/><mxPoint x="210" y="158"/></Array></mxGeometry></mxCell><mxCell id="cfg_g_5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="cfg" target="g"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="g_adv_6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="g" target="adv"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="adv_rc_7" value="candidate prompt" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="adv" target="rc"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="rc_tg_8" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="rc" target="tg"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="tg_rsp_9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="tg" target="rsp"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="rsp_dref_10" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="rsp" target="dref"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="dref_bt_11" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;dashPattern=8 4;strokeColor=#455A64;strokeWidth=1.8;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="dref" target="bt"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="bt_g_12" value="regenerate turn<br>(no turn spent)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="bt" target="g"><mxGeometry relative="1" as="geometry"><Array as='points'><mxPoint x="30" y="702"/><mxPoint x="30" y="321"/></Array></mxGeometry></mxCell><mxCell id="dref_sc_13" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="dref" target="sc"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="dobj_ok_14" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="dobj" target="ok"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="dobj_inc_15" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="dobj" target="inc"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="sc_dobj_16" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="sc" target="dobj"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="inc_dturn_17" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="inc" target="dturn"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="dturn_bad_18" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="dturn" target="bad"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="dturn_g_19" value="yes — next turn<br>last_response + last_score fed back<br>(use_score_as_feedback=True)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="dturn" target="g"><mxGeometry relative="1" as="geometry"><Array as='points'><mxPoint x="410" y="1130"/><mxPoint x="410" y="321"/></Array></mxGeometry></mxCell></root></mxGraphModel></diagram><diagram name="TAP (Tree of Attacks)" id="page3"><mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" page="1" pageWidth="1169" pageHeight="826" math="0" shadow="1"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="t" value="<b>PyRIT — TAPAttack (Tree of Attacks with Pruning)</b><br><font style='font-size:11px' color='#607D8B'>the multi-turn loop, run as a beam search: branch → score → prune → deepen</font>" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=20;fontStyle=1;fontColor=#102027;" vertex="1" parent="1"><mxGeometry x="40" y="24" width="0" height="0" as="geometry"/></mxCell><mxCell id="root" value="<b>Objective</b><br><font style='font-size:10px' color='#546E7A'>TAPAttackContext</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#E3F2FD;strokeColor=#1565C0;fontColor=#0D47A1;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="420" y="96" width="280" height="58" as="geometry"/></mxCell><mxCell id="d1" value="<b>Depth 1 — branch</b><br><font style='font-size:10px' color='#546E7A'>adversarial LLM emits branching_factor variants</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#FCE4EC;strokeColor=#AD1457;fontColor=#880E4F;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="420" y="190" width="280" height="50" as="geometry"/></mxCell><mxCell id="a0" value="<b>TAPNode 1</b><br><font style='font-size:10px' color='#546E7A'>own conversation_id + adversarial history</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#FFFFFF;strokeColor=#455A64;fontColor=#263238;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="120" y="268" width="260" height="54" as="geometry"/></mxCell><mxCell id="s0" value="<b>send → objective_target</b><br><font style='font-size:10px' color='#546E7A'>on-topic check, then objective_scorer</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1B5E20;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="120" y="350" width="260" height="54" as="geometry"/></mxCell><mxCell id="a1" value="<b>TAPNode 2</b><br><font style='font-size:10px' color='#546E7A'>own conversation_id + adversarial history</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#FFFFFF;strokeColor=#455A64;fontColor=#263238;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="420" y="268" width="260" height="54" as="geometry"/></mxCell><mxCell id="s1" value="<b>send → objective_target</b><br><font style='font-size:10px' color='#546E7A'>on-topic check, then objective_scorer</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1B5E20;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="420" y="350" width="260" height="54" as="geometry"/></mxCell><mxCell id="a2" value="<b>TAPNode 3</b><br><font style='font-size:10px' color='#546E7A'>own conversation_id + adversarial history</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#FFFFFF;strokeColor=#455A64;fontColor=#263238;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="720" y="268" width="260" height="54" as="geometry"/></mxCell><mxCell id="s2" value="<b>send → objective_target</b><br><font style='font-size:10px' color='#546E7A'>on-topic check, then objective_scorer</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1B5E20;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="720" y="350" width="260" height="54" as="geometry"/></mxCell><mxCell id="prune" value="<b>Prune to width</b><br><font style='font-size:10px' color='#546E7A'>keep top-N by score; off-topic / blocked</font><br><font style='font-size:10px' color='#546E7A'>branches scored 0 → dropped (nodes_pruned)</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#FFEBEE;strokeColor=#C62828;fontColor=#B71C1C;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="420" y="434" width="280" height="62" as="geometry"/></mxCell><mxCell id="d2" value="<b>Depth 2 — branch survivors</b><br><font style='font-size:10px' color='#546E7A'>each surviving node duplicated into children</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#FCE4EC;strokeColor=#AD1457;fontColor=#880E4F;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="420" y="528" width="280" height="50" as="geometry"/></mxCell><mxCell id="dchk" value="<b>any score</b><br><font style='font-size:10px' color='#546E7A'>== objective met ?</font>" style="rhombus;whiteSpace=wrap;html=1;dashed=0;fillColor=#FFFDE7;strokeColor=#F9A825;fontColor=#795548;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="440" y="620" width="240" height="92" as="geometry"/></mxCell><mxCell id="ok" value="<b>TAPAttackResult</b><br><font style='font-size:10px' color='#546E7A'>outcome = SUCCESS · best branch conversation</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1B5E20;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="800" y="634" width="270" height="64" as="geometry"/></mxCell><mxCell id="ddep" value="<b>depth &lt; max_depth ?</b>" style="rhombus;whiteSpace=wrap;html=1;dashed=0;fillColor=#FFFDE7;strokeColor=#F9A825;fontColor=#795548;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="440" y="752" width="240" height="92" as="geometry"/></mxCell><mxCell id="bad2" value="<b>TAPAttackResult</b><br><font style='font-size:10px' color='#546E7A'>outcome = FAILURE · nodes_pruned, max_depth_reached</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#FFEBEE;strokeColor=#C62828;fontColor=#B71C1C;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="800" y="766" width="270" height="64" as="geometry"/></mxCell><mxCell id="note" value="<b>Why it matters for ASR</b><br><font style='font-size:10px' color='#546E7A'>TAP spends far more target calls per objective than RedTeaming (≈ width × depth × branching_factor), but it recovers from a bad opening move instead of burning the whole budget on one line of attack.</font><br><font style='font-size:10px' color='#546E7A'>PAIRAttack is the degenerate case: width = 1, i.e. refine a single branch. Single-turn strategies are the other extreme: depth = 1, no feedback, cheapest per objective.</font><br><font style='font-size:10px' color='#546E7A'>Every node&#x27;s conversation is persisted to CentralMemory and cross-linked on AttackResult.related_conversations — pruned branches stay auditable.</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#FAFAFA;strokeColor=#9E9E9E;fontColor=#424242;fontSize=12;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="120" y="880" width="950" height="96" as="geometry"/></mxCell><mxCell id="d1_a0_0" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="d1" target="a0"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="a0_s0_1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="a0" target="s0"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="d1_a1_2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="d1" target="a1"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="a1_s1_3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="a1" target="s1"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="d1_a2_4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="d1" target="a2"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="a2_s2_5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="a2" target="s2"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="root_d1_6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="root" target="d1"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="s0_prune_7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="s0" target="prune"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="s1_prune_8" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="s1" target="prune"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="s2_prune_9" value="" style="edgeS