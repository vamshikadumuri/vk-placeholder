mxCell><mxCell id="ddep_d1_14" value="yes — next depth" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="ddep" target="d1"><mxGeometry relative="1" as="geometry"><Array as='points'><mxPoint x="80" y="798"/><mxPoint x="80" y="215"/></Array></mxGeometry></mxCell><mxCell id="ddep_bad2_15" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="ddep" target="bad2"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell></root></mxGraphModel></diagram></mxfile>