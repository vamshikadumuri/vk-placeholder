"n4" value="<b>response_converters</b><br><font style='font-size:10px' color='#546E7A'>normalise target output</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#EDE7F6;strokeColor=#5E35B1;fontColor=#311B92;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="390" y="462" width="280" height="58" as="geometry"/></mxCell><mxCell id="n5" value="<b>_evaluate_response_async()</b><br><font style='font-size:10px' color='#546E7A'>AttackScoringConfig: auxiliary_scorers,</font><br><font style='font-size:10px' color='#546E7A'>then objective_scorer (TrueFalseScorer)</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1B5E20;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="390" y="554" width="280" height="62" as="geometry"/></mxCell><mxCell id="d1" value="<b>score == True ?</b>" style="rhombus;whiteSpace=wrap;html=1;dashed=0;fillColor=#FFFDE7;strokeColor=#F9A825;fontColor=#795548;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="410" y="648" width="240" height="92" as="geometry"/></mxCell><mxCell id="d2" value="<b>attempt &lt;</b><br><font style='font-size:10px' color='#546E7A'>_max_attempts_on_failure ?</font>" style="rhombus;whiteSpace=wrap;html=1;dashed=0;fillColor=#FFFDE7;strokeColor=#F9A825;fontColor=#795548;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="410" y="790" width="240" height="92" as="geometry"/></mxCell><mxCell id="retry" value="<b>Retry</b><br><font style='font-size:10px' color='#546E7A'>mark conversation PRUNED,</font><br><font style='font-size:10px' color='#546E7A'>_setup_async() → fresh conversation</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#E3F2FD;strokeColor=#1565C0;fontColor=#0D47A1;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="80" y="802" width="250" height="68" as="geometry"/></mxCell><mxCell id="ok" value="<b>AttackResult</b><br><font style='font-size:10px' color='#546E7A'>outcome = SUCCESS</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#E8F5E9;strokeColor=#2E7D32;fontColor=#1B5E20;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="740" y="662" width="250" height="64" as="geometry"/></mxCell><mxCell id="bad" value="<b>AttackResult</b><br><font style='font-size:10px' color='#546E7A'>outcome = FAILURE / UNDETERMINED</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#FFEBEE;strokeColor=#C62828;fontColor=#B71C1C;fontSize=12;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="390" y="930" width="280" height="64" as="geometry"/></mxCell><mxCell id="note" value="<b>Single-turn strategies</b><br><font style='font-size:10px' color='#546E7A'></font><br><font style='font-size:10px'><b>PromptSendingAttack</b></font><br><font style='font-size:10px' color='#546E7A'>baseline: send objective / seed prompt as-is</font><br><font style='font-size:10px' color='#546E7A'></font><br><font style='font-size:10px'><b>ContextComplianceAttack</b></font><br><font style='font-size:10px' color='#546E7A'>fake benign Q&amp;A history, then the ask</font><br><font style='font-size:10px' color='#546E7A'></font><br><font style='font-size:10px'><b>FlipAttack</b></font><br><font style='font-size:10px' color='#546E7A'>character/word-order flip + decode instruction</font><br><font style='font-size:10px' color='#546E7A'></font><br><font style='font-size:10px'><b>ManyShotJailbreakAttack</b></font><br><font style='font-size:10px' color='#546E7A'>N in-context examples of compliance</font><br><font style='font-size:10px' color='#546E7A'></font><br><font style='font-size:10px'><b>RolePlayAttack</b></font><br><font style='font-size:10px' color='#546E7A'>persona framing (RolePlayPaths)</font><br><font style='font-size:10px' color='#546E7A'></font><br><font style='font-size:10px'><b>SkeletonKeyAttack</b></font><br><font style='font-size:10px' color='#546E7A'>two-step &#x27;add a warning instead of refusing&#x27;</font><br><font style='font-size:10px' color='#546E7A'></font><br><font style='font-size:10px' color='#546E7A'>All differ ONLY in how the one message</font><br><font style='font-size:10px' color='#546E7A'>is built. No adversarial LLM in the loop;</font><br><font style='font-size:10px' color='#546E7A'>diversity comes from converters + seed.</font>" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;dashed=0;fillColor=#FAFAFA;strokeColor=#9E9E9E;fontColor=#424242;fontSize=12;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;shadow=1;" vertex="1" parent="1"><mxGeometry x="730" y="186" width="300" height="420" as="geometry"/></mxCell><mxCell id="l1_l2_0" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="l1" target="l2"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="l2_l3_1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="l2" target="l3"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="l3_l4_2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#455A64;strokeWidth=1.8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontColor=#37474F;fontStyle=2;labelBackgroundColor=#FFFFFF;endArrow=blockThin;endFill=1;" edge="1" parent="1" s